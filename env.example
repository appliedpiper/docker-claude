# Copy this file to .env and fill in your key:
#   cp .env.example .env
#
# Get an API key from https://console.anthropic.com/
# Comment out this line if you want to login via Claude AI portal
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-fable-5

# Path to the project you want Claude Code to read/edit, relative to this
# compose file (or absolute). Leave unset to default to ./project.
# Examples:
#   PROJECT_PATH=./project
#   PROJECT_PATH=../my-app
#   PROJECT_PATH=/home/you/code/my-app
PROJECT_PATH=

# Where Claude Code's config/auth/session history is stored.
# Leave unset (recommended) to use the named Docker volume `claude-config`,
# which persists across container rebuilds without cluttering your project.
# Set this to a host path instead only if you want those files directly
# browsable/backupable on your machine, e.g.:
#   CLAUDE_CONFIG_PATH=./claude-config
CLAUDE_CONFIG_PATH=

# Optional: match your host user so bind-mounted files aren't root-owned.
# Run `id -u` and `id -g` on your host to find these.
USER_UID=1000
USER_GID=1000